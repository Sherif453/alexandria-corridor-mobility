{
  "name": "alex-mobility",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false --incremental false",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "python:setup": "python3 -m venv --clear .venv && .venv/bin/python -m pip install -r python/requirements.txt",
    "db:seed": "TMPDIR=.tmp tsx prisma/seed.ts",
    "features:build": "python3 python/features/build_features.py",
    "models:train": ".venv/bin/python python/models/train_baseline.py",
    "predictions:generate": ".venv/bin/python python/models/generate_predictions.py",
    "scenarios:run": "python3 python/simulation/run_sumo_scenarios.py",
    "ingest:once": "TMPDIR=.tmp tsx scripts/ingest/run.ts",
    "ingest:scheduler": "TMPDIR=.tmp tsx scripts/ingest/scheduler.ts",
    "test": "TMPDIR=.tmp node --import tsx --test tests/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "6.19.3",
    "dotenv": "^17.4.2",
    "leaflet": "^1.9.4",
    "next": "^16.2.3",
    "node-cron": "^4.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.5.9",
    "prisma": "6.19.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
